<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:m="using:SourceGit.Models"
             xmlns:vm="using:SourceGit.ViewModels"
             xmlns:v="using:SourceGit.Views"
             xmlns:c="using:SourceGit.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SourceGit.Views.CheckoutDetached"
             x:DataType="vm:CheckoutDetached">
  <StackPanel Orientation="Vertical" Margin="8,0">
    <StackPanel Orientation="Horizontal">
      <Path Width="16" Height="16"
            Data="{StaticResource Icons.Detached}"/>

      <TextBlock FontSize="18"
                 Margin="8,0,0,0"
                 Classes="bold"
                 Text="{DynamicResource Text.CheckoutDetached}"/>
    </StackPanel>

    <Grid Margin="0,16,0,0" RowDefinitions="32,Auto,Auto">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" MinWidth="140"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Row="0" Grid.Column="0"
                 HorizontalAlignment="Right" VerticalAlignment="Center"
                 Margin="0,0,8,0"
                 Text="{DynamicResource Text.CheckoutDetached.Target}" />
      <ContentControl Grid.Row="0" Grid.Column="1" Content="{Binding Target, Mode=OneWay}">
        <ContentControl.DataTemplates>
          <DataTemplate DataType="m:Commit">
            <Grid ColumnDefinitions="Auto,Auto,*">
              <Path Grid.Column="0" Width="14" Height="14" Data="{StaticResource Icons.Commit}" />
              <TextBlock Grid.Column="1"
                         FontFamily="{DynamicResource Fonts.Monospace}"
                         Foreground="DarkOrange"
                         VerticalAlignment="Center"
                         Margin="8,0"
                         Text="{Binding SHA, Converter={x:Static c:StringConverters.ToShortSHA}}" />
              <TextBlock Grid.Column="2"
                         Text="{Binding Subject, Mode=OneWay}"
                         TextTrimming="CharacterEllipsis"/>
            </Grid>
          </DataTemplate>

          <DataTemplate DataType="m:Tag">
            <Grid ColumnDefinitions="Auto,*">
              <Path Grid.Column="0" Width="14" Height="14" Data="{StaticResource Icons.Tag}" />
              <TextBlock Grid.Column="1" Margin="8,0" Text="{Binding Name, Mode=OneWay}" TextTrimming="CharacterEllipsis"/>
            </Grid>
          </DataTemplate>
        </ContentControl.DataTemplates>
      </ContentControl>

      <Border Grid.Row="1" Grid.Column="0"
              Height="32"
              VerticalAlignment="Top"
              IsVisible="{Binding HasLocalChanges, Mode=OneWay}">
        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                   Margin="0,0,8,0"
                   Text="{DynamicResource Text.Checkout.LocalChanges}"/>
      </Border>
      <v:DealWithLocalChangesMethod Grid.Row="1" Grid.Column="1"
                                    Method="{Binding DealWithLocalChanges, Mode=TwoWay}"
                                    IsVisible="{Binding HasLocalChanges, Mode=OneWay}"/>

      <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="Auto,*" Margin="0,6,0,0">
        <Path Grid.Column="0"
              Width="14" Height="14"
              Data="{StaticResource Icons.Error}"
              Fill="DarkOrange"/>
        <TextBlock Grid.Column="1" Margin="8,0,0,0"
                   Text="{DynamicResource Text.CheckoutDetached.Warning}"
                   TextWrapping="Wrap"
                   Foreground="DarkOrange"/>
      </Grid>
    </Grid>
  </StackPanel>
</UserControl>
